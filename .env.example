# CiaLli 环境变量配置示例
# 复制此文件为 .env 并根据需要填写实际值

# ============================================
# Directus (Headless CMS)
# ============================================

# Directus 实例地址，例如:
# DIRECTUS_URL=https://cms.example.com
DIRECTUS_URL=

# 服务端访问 Directus 的静态 Token
DIRECTUS_STATIC_TOKEN=

# Bangumi AccessToken 加密密钥（base64 编码的 32-byte key）
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BANGUMI_TOKEN_ENCRYPTION_KEY=

# 可选：公开资源基础地址（用于图床）
# 未配置时将回退到站内资源代理路径（/api/v1/public/assets/:id）
PUBLIC_ASSET_BASE_URL=

# ============================================
# Upstash Redis
# ============================================
# Redis 命名空间。生产环境必须显式配置，避免与开发/预览环境混用。
# 推荐取值：
# production -> prod
# local development -> dev:local
# preview branch -> preview:feature-about
REDIS_NAMESPACE=
# Upstash Redis REST API URL（Vercel 集成变量名）
KV_REST_API_URL=
# Upstash Redis REST API Token（Vercel 集成变量名）
KV_REST_API_TOKEN=
