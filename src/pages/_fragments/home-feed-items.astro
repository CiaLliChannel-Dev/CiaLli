---
import HomeFeedItemsContent from "@/components/home/HomeFeedItems.astro";
import { getSessionUser } from "@/server/auth/session";
import {
  buildHomeFeedPage,
  DEFAULT_HOME_FEED_ARTICLE_CANDIDATE_LIMIT,
  DEFAULT_HOME_FEED_DIARY_CANDIDATE_LIMIT,
  DEFAULT_HOME_FEED_TOTAL_LIMIT,
  MAX_HOME_FEED_PAGE_LIMIT,
} from "@/server/application/feed/home-feed.service";
import {
  DIRECTUS_ACCESS_COOKIE_NAME,
  DIRECTUS_REFRESH_COOKIE_NAME,
} from "@/server/directus-auth";

export const prerender = false;
export const partial = true;

const DEFAULT_BATCH_LIMIT = 5;

function parseNonNegativeInt(value: string | null, fallback: number): number {
  if (!value) {
    return fallback;
  }
  const parsed = Number(value);
  if (!Number.isFinite(parsed) || parsed < 0) {
    return fallback;
  }
  return Math.floor(parsed);
}

function hasAuthCookies(): boolean {
  return Boolean(
    Astro.cookies.get(DIRECTUS_ACCESS_COOKIE_NAME)?.value ||
    Astro.cookies.get(DIRECTUS_REFRESH_COOKIE_NAME)?.value,
  );
}

const offset = parseNonNegativeInt(Astro.url.searchParams.get("offset"), 0);
const parsedLimit = parseNonNegativeInt(
  Astro.url.searchParams.get("limit"),
  DEFAULT_BATCH_LIMIT,
);
const limit = Math.min(MAX_HOME_FEED_PAGE_LIMIT, Math.max(1, parsedLimit));
const sessionUser = hasAuthCookies() ? await getSessionUser(Astro) : null;
const result = await buildHomeFeedPage({
  viewerId: sessionUser?.id ?? null,
  viewerRoleName: sessionUser?.roleName ?? null,
  isViewerSystemAdmin: sessionUser?.isSystemAdmin ?? false,
  offset,
  pageLimit: limit,
  totalLimit: DEFAULT_HOME_FEED_TOTAL_LIMIT,
  articleCandidateLimit: DEFAULT_HOME_FEED_ARTICLE_CANDIDATE_LIMIT,
  diaryCandidateLimit: DEFAULT_HOME_FEED_DIARY_CANDIDATE_LIMIT,
});

Astro.response.headers.set(
  "X-Home-Feed-Next-Offset",
  String(result.next_offset),
);
Astro.response.headers.set(
  "X-Home-Feed-Has-More",
  result.has_more ? "true" : "false",
);

if (hasAuthCookies() || sessionUser?.id) {
  Astro.response.headers.set("Cache-Control", "private, no-store");
} else {
  Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=60, stale-while-revalidate=300",
  );
}
---

<!--
  后续批次必须复用首屏同一份服务端模板，避免再次维护字符串拼接卡片。
-->
<HomeFeedItemsContent items={result.items} />
