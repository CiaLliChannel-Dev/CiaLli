---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import HomeFeedPage from "@components/home/HomeFeedPage.astro";
import {
  buildHomeFeedPage,
  DEFAULT_HOME_FEED_TOTAL_LIMIT,
  HOME_FEED_HOME_PAGE_LIMIT,
} from "@/server/application/feed/home-feed.service";
import { getSessionUser } from "@/server/auth/session";
import {
  DIRECTUS_ACCESS_COOKIE_NAME,
  DIRECTUS_REFRESH_COOKIE_NAME,
} from "@/server/directus-auth";
import type { HomeFeedPageItem } from "@/server/recommendation/home-feed.types";

export const prerender = false;
const rawPagePath = Astro.params.page || "";

// 重定向旧分页 URL
if (rawPagePath) {
  const isOldPagination =
    /^\d+$/.test(rawPagePath) || /^page\/\d+$/i.test(rawPagePath);
  if (isOldPagination) {
    return Astro.redirect("/", 301);
  }
  // 非分页路径 → 404
  Astro.response.status = 404;
}

let homeFeedItems: HomeFeedPageItem[] = [];
const invalidPath = Boolean(rawPagePath);
let sessionUserId: string | null = null;
const hasSessionCookie = Boolean(
  Astro.cookies.get(DIRECTUS_ACCESS_COOKIE_NAME)?.value ||
  Astro.cookies.get(DIRECTUS_REFRESH_COOKIE_NAME)?.value,
);

if (!invalidPath) {
  try {
    const sessionUser = hasSessionCookie ? await getSessionUser(Astro) : null;
    sessionUserId = sessionUser?.id ?? null;
    const homeFeed = await buildHomeFeedPage({
      viewerId: sessionUser?.id ?? null,
      viewerRoleName: sessionUser?.roleName ?? null,
      isViewerSystemAdmin: sessionUser?.isSystemAdmin ?? false,
      offset: 0,
      pageLimit: HOME_FEED_HOME_PAGE_LIMIT,
      totalLimit: DEFAULT_HOME_FEED_TOTAL_LIMIT,
    });
    homeFeedItems = homeFeed.items;
  } catch (error) {
    console.error("[home] failed to load mixed feed:", error);
  }
}

if (!invalidPath) {
  if (hasSessionCookie || sessionUserId) {
    Astro.response.headers.set("Cache-Control", "private, no-store");
  } else {
    Astro.response.headers.set(
      "Cache-Control",
      "public, s-maxage=60, stale-while-revalidate=300",
    );
  }
}
---

<MainGridLayout>
  {
    invalidPath ? (
      <div class="card-base p-8 rounded-(--radius-large)">
        <h1 class="text-2xl font-bold mb-2">
          {i18n(I18nKey.coreNotFoundTitle)}
        </h1>
        <p class="text-70">{i18n(I18nKey.contentPageNotFoundPathCheck)}</p>
      </div>
    ) : (
      <div class="home-layout">
        <div class="min-w-0">
          {homeFeedItems.length === 0 ? (
            <div class="card-base p-8 rounded-(--radius-large) text-70 mb-4">
              {i18n(I18nKey.contentPageNoPublicPosts)}
            </div>
          ) : (
            <HomeFeedPage items={homeFeedItems} maxAnimationIndex={15} />
          )}
          {/* 首页首屏收敛后仅保留归档入口，不再继续下拉加载 */}
          <a href="/posts" class="home-archive-cta card-base">
            {i18n(I18nKey.coreViewMore)}
          </a>
        </div>
        {/* 右侧占位，与归档页筛选面板等宽 */}
        <div class="home-sidebar-placeholder" />
      </div>
    )
  }
</MainGridLayout>

<style>
  .home-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .home-sidebar-placeholder {
    display: none;
  }

  .home-archive-cta {
    display: inline-flex;
    width: 100%;
    min-height: 4.5rem;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 1.35rem;
    font-weight: 700;
    color: rgb(0 0 0 / 0.9);
  }

  .home-archive-cta:hover {
    color: var(--primary);
  }

  :global(:root.dark) .home-archive-cta {
    color: rgb(255 255 255 / 0.9);
  }

  @media (min-width: 1280px) {
    .home-layout {
      grid-template-columns: 1fr 17.5rem;
    }

    .home-sidebar-placeholder {
      display: block;
    }
  }
</style>
