---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import FeedPage from "@components/feed/FeedPage.astro";
import {
  buildMixedFeedPage,
  DEFAULT_MIXED_FEED_TOTAL_LIMIT,
  MIXED_FEED_HOME_PAGE_LIMIT,
} from "@/server/application/feed/mixed-feed-page.service";
import type { FeedPageItem } from "@/server/application/feed/feed.types";

const rawPagePath = Astro.params.page || "";

// 重定向旧分页 URL
if (rawPagePath) {
  const isOldPagination =
    /^\d+$/.test(rawPagePath) || /^page\/\d+$/i.test(rawPagePath);
  if (isOldPagination) {
    return Astro.redirect("/", 301);
  }
  // 非分页路径 → 404
  Astro.response.status = 404;
}

let mixedFeedItems: FeedPageItem[] = [];
const invalidPath = Boolean(rawPagePath);

if (!invalidPath) {
  try {
    const mixedFeed = await buildMixedFeedPage({
      offset: 0,
      pageLimit: MIXED_FEED_HOME_PAGE_LIMIT,
      totalLimit: DEFAULT_MIXED_FEED_TOTAL_LIMIT,
    });
    mixedFeedItems = mixedFeed.items;
  } catch (error) {
    console.error("[home] failed to load mixed feed:", error);
  }
}

if (!invalidPath) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=300, stale-while-revalidate=900",
  );
}
---

<MainGridLayout>
  {
    invalidPath ? (
      <div class="card-base p-8 rounded-(--radius-large)">
        <h1 class="text-2xl font-bold mb-2">
          {i18n(I18nKey.coreNotFoundTitle)}
        </h1>
        <p class="text-70">{i18n(I18nKey.contentPageNotFoundPathCheck)}</p>
      </div>
    ) : (
      <div class="home-layout">
        <div class="min-w-0">
          {mixedFeedItems.length === 0 ? (
            <div class="card-base p-8 rounded-(--radius-large) text-70 mb-4">
              {i18n(I18nKey.contentPageNoPublicPosts)}
            </div>
          ) : (
            <FeedPage items={mixedFeedItems} maxAnimationIndex={15} />
          )}
          {/* 首页首屏收敛后仅保留文章列表入口，不再继续下拉加载 */}
          <a href="/posts" class="home-article-list-cta card-base">
            {i18n(I18nKey.coreViewMore)}
          </a>
        </div>
        {/* 右侧占位，与文章列表筛选面板等宽 */}
        <div class="home-sidebar-placeholder" />
      </div>
    )
  }
</MainGridLayout>

<style>
  .home-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .home-sidebar-placeholder {
    display: none;
  }

  .home-article-list-cta {
    display: inline-flex;
    width: 100%;
    min-height: 4.5rem;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 1.35rem;
    font-weight: 700;
    color: rgb(0 0 0 / 0.9);
  }

  .home-article-list-cta:hover {
    color: var(--primary);
  }

  :global(:root.dark) .home-article-list-cta {
    color: rgb(255 255 255 / 0.9);
  }

  @media (min-width: 1280px) {
    .home-layout {
      grid-template-columns: 1fr 17.5rem;
    }

    .home-sidebar-placeholder {
      display: block;
    }
  }
</style>
