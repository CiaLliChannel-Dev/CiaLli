---
import { Icon } from "astro-icon/components";

import ExternalImage from "@components/misc/ExternalImage.astro";
import type { HomeFeedViewerState } from "@/server/recommendation/home-feed.types";
import type { DirectusPostEntry } from "@/utils/content-utils";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { resolveAuthorIdentity } from "@/utils/author-identity";
import { getPostUrl } from "@/utils/url-utils";

interface Props {
  class?: string;
  entry: DirectusPostEntry;
  style?: string;
  viewerState?: HomeFeedViewerState;
}

const { entry, style } = Astro.props;
const className = Astro.props.class;
const viewerState: HomeFeedViewerState = Astro.props.viewerState ?? {
  hasLiked: false,
  canDeleteOwn: false,
  canDeleteAdmin: false,
  canBlock: false,
};

const {
  title,
  published,
  description,
  image,
  pinned,
  author,
  author_id,
  article_id,
  comment_count,
  like_count,
} = entry.data as DirectusPostEntry["data"] & {
  pinned?: boolean;
};

const url = getPostUrl(entry);
const hasCover = typeof image === "string" && image.trim().length > 0;
const coverWidth = "28%";
const desktopBodyWidthClass = hasCover
  ? "lg:w-[calc(100%-var(--coverWidth)-0.75rem)]"
  : "lg:w-[calc(100%-3.25rem-0.75rem)]";
const desktopEnterLinkClass = hasCover
  ? "lg:w-[var(--coverWidth)]"
  : "lg:w-[3.25rem]";
const bodyText = entry.data.encrypted
  ? ""
  : String(entry.body || "")
      .replace(/<[^>]+>/g, " ")
      .replace(/\s+/g, " ")
      .trim();
const excerpt = description || bodyText.slice(0, 30) || "";
const { displayName: authorDisplayName, username: authorHandle } =
  resolveAuthorIdentity(
    {
      id: author?.id,
      name: author?.name,
      username: author?.username,
      display_name: author?.display_name,
    },
    author_id,
  );
const publishedDateSource = new Date(published);
const publishedDate = !Number.isNaN(publishedDateSource.getTime())
  ? `${publishedDateSource.getFullYear()}/${String(publishedDateSource.getMonth() + 1).padStart(2, "0")}/${String(publishedDateSource.getDate()).padStart(2, "0")}`
  : "1970/01/01";
const adminDeleteLabel = i18n(I18nKey.interactionCommonDeleteAdmin);
---

<div
  class:list={[
    "card-base flex flex-col w-full rounded-(--radius-large) overflow-hidden relative",
    className,
  ]}
  style={style}
  data-post-card
  data-article-id={article_id}
  data-author-id={author_id}
  data-author-handle={authorHandle}
  data-enter-skeleton-target="post-card"
>
  <div data-enter-skeleton-content class="relative flex flex-col lg:block">
    <a
      href={url}
      aria-label={title}
      tabindex="-1"
      class="absolute inset-0 z-10 rounded-(--radius-large) lg:hidden"
    >
    </a>
    <div
      class:list={[
        "relative flex flex-col gap-3.5 px-4 py-4 sm:px-5 sm:py-5 lg:gap-4 lg:pl-9 lg:pr-2 lg:pt-7 lg:pb-6",
        desktopBodyWidthClass,
      ]}
    >
      <a
        href={url}
        class="relative z-20 transition w-full block font-bold text-xl leading-tight sm:text-2xl lg:text-3xl text-90
          hover:text-(--primary) dark:hover:text-(--primary)
          active:text-(--title-active) dark:active:text-(--title-active)
          before:content-[''] before:absolute before:-left-4
          before:top-[0.18em] before:bottom-[0.18em]
          before:w-1 before:rounded-md before:bg-(--primary)
          lg:before:-left-[1.125rem]"
      >
        {
          pinned && (
            <Icon
              name="mdi:pin"
              class="inline text-(--primary) text-2xl mr-2 -translate-y-0.5"
            />
          )
        }
        {title}
      </a>

      <div class="hidden lg:block h-5" aria-hidden="true"></div>

      <div
        class="transition text-sm leading-6 text-75 mb-0 md:text-base lg:-mt-3 lg:mb-3.5 lg:pr-4 line-clamp-2 md:line-clamp-3 lg:line-clamp-1"
      >
        {excerpt}
      </div>

      <div
        class="flex flex-col items-start gap-3 mt-auto md:gap-3.5 lg:-mt-2 lg:flex-row lg:items-center lg:justify-between"
      >
        <div
          class="flex min-w-0 flex-wrap items-center gap-1.5 text-50 text-xs font-medium leading-5 sm:text-sm sm:leading-none"
        >
          <div class="max-w-[14rem] min-w-0 inline-flex items-baseline gap-1">
            <a
              href={`/${authorHandle}`}
              class="relative z-20 truncate text-90 border-b border-transparent hover:border-current"
            >
              {authorDisplayName}
            </a>
            <a
              href={`/${authorHandle}`}
              class="relative z-20 shrink-0 text-60 hover:text-(--primary) transition-colors"
            >
              {"@"}
              {authorHandle}
            </a>
          </div>
          <span class="text-(--meta-divider)" aria-hidden="true">·</span>
          <span>{publishedDate}</span>
        </div>
        <div
          class="flex w-full items-center justify-between gap-3 shrink-0 post-card-actions leading-none md:gap-4 lg:ml-3 lg:mr-2 lg:w-auto lg:justify-start"
        >
          <button
            type="button"
            class:list={[
              "relative z-20 inline-flex h-6 items-center gap-1.5 text-base font-medium hover:text-(--primary) transition-colors post-card-action-btn",
              {
                "text-(--primary)": viewerState.hasLiked,
                "text-50": !viewerState.hasLiked,
              },
            ]}
            data-action="toggle-like"
            data-liked={viewerState.hasLiked ? "true" : "false"}
            data-like-count={like_count}
            aria-label="切换点赞"
          >
            <Icon name="material-symbols:thumb-up-rounded" class="text-xl" />
            <span data-like-count>{like_count}</span>
          </button>
          <a
            href={`${url}#comment-root`}
            class="relative z-20 inline-flex h-6 items-center gap-1.5 text-50 text-base font-medium hover:text-(--primary) transition-colors"
          >
            <Icon name="material-symbols:comment-rounded" class="text-xl" />
            <span>{comment_count}</span>
          </a>
          <details class="relative z-20 post-card-menu">
            <summary
              class="list-none cursor-pointer inline-flex items-center justify-center w-8 h-8 rounded-lg text-50 hover:text-(--primary) hover:bg-(--btn-plain-bg-hover) active:bg-(--btn-plain-bg-active) transition-colors"
              aria-label="更多操作"
            >
              <Icon name="material-symbols:more-horiz" class="text-xl" />
            </summary>
            <div
              class="absolute right-0 bottom-full mb-2 z-30 min-w-[12rem] rounded-xl border border-black/5 dark:border-white/10 bg-(--float-panel-bg) p-1.5 shadow-xl dark:shadow-none"
            >
              <button
                type="button"
                class:list={[
                  "w-full text-left px-3 py-2 text-sm rounded-lg text-red-500 hover:text-red-500 hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors",
                  {
                    hidden: !viewerState.canDeleteOwn,
                  },
                ]}
                data-action="delete-own-article"
              >
                删除文章
              </button>
              <button
                type="button"
                class:list={[
                  "w-full text-left px-3 py-2 text-sm rounded-lg text-red-500 hover:text-red-500 hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors",
                  {
                    hidden: !viewerState.canDeleteAdmin,
                  },
                ]}
                data-action="delete-admin-article"
              >
                {adminDeleteLabel}
              </button>
              <button
                type="button"
                class:list={[
                  "w-full text-left px-3 py-2 text-sm rounded-lg text-black/75 dark:text-white/75 hover:text-(--primary) hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors",
                  {
                    hidden: !viewerState.canBlock,
                  },
                ]}
                data-action="block-user"
              >
                屏蔽用户
              </button>
            </div>
          </details>
        </div>
      </div>
    </div>

    {
      hasCover ? (
        <a
          href={url}
          aria-label={title}
          class:list={[
            "group relative mx-4 mb-4 block h-44 rounded-xl overflow-hidden active:scale-95 sm:mx-5 sm:mb-5 sm:h-48 md:h-52 lg:absolute lg:top-3 lg:right-3 lg:bottom-3 lg:mx-0 lg:mb-0 lg:h-auto",
            desktopEnterLinkClass,
          ]}
        >
          <div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition" />
          <div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center">
            <Icon
              name="material-symbols:chevron-right-rounded"
              class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl"
            />
          </div>
          <ExternalImage
            src={image || ""}
            alt={`Cover image of ${title}`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </a>
      ) : (
        <a
          href={url}
          aria-label={title}
          class="hidden mx-5 mb-5 h-12 rounded-xl btn-regular bg-(--enter-btn-bg) hover:bg-(--enter-btn-bg-hover) active:bg-(--enter-btn-bg-active) active:scale-95 lg:absolute lg:right-3 lg:top-3 lg:bottom-3 lg:mx-0 lg:mb-0 lg:flex lg:h-auto lg:w-[3.25rem]"
        >
          <Icon
            name="material-symbols:chevron-right-rounded"
            class="transition text-(--primary) text-4xl mx-auto"
          />
        </a>
      )
    }
  </div>
  <div
    data-enter-skeleton-placeholder
    aria-hidden="true"
    class="absolute inset-0 z-20 pointer-events-none"
  >
    <div class="relative flex h-full flex-col lg:block">
      <div
        class:list={[
          "px-4 py-4 flex flex-col gap-3.5 sm:px-5 sm:py-5 lg:h-full lg:gap-4 lg:pl-9 lg:pr-2 lg:pt-7 lg:pb-6",
          desktopBodyWidthClass,
        ]}
      >
        <div class="space-y-3.5 lg:space-y-4">
          <div class="relative block">
            <div
              class="absolute top-1 bottom-1 -left-4 md3-skeleton-block w-1 rounded-md lg:-left-[1.125rem]"
            >
            </div>
            <div
              class="md3-skeleton-text"
              style="--skeleton-width: 42%; --skeleton-height: 2rem;"
            >
            </div>
          </div>

          <div class="h-5" aria-hidden="true"></div>

          <div class="-mt-3">
            <div class="md3-skeleton-text" style="--skeleton-width: 48%;"></div>
          </div>
        </div>
        <div
          class="mt-auto flex flex-col items-start gap-3 pt-2 md:gap-3.5 lg:flex-row lg:items-center lg:justify-between lg:gap-4 lg:pt-2.5"
        >
          <div class="flex min-w-0 flex-wrap items-center gap-2">
            <div
              class="md3-skeleton-text"
              style="--skeleton-width: 9.5rem; --skeleton-height: 1.45rem;"
            >
            </div>
            <div class="md3-skeleton-circle h-1.5 w-1.5 shrink-0"></div>
            <div
              class="md3-skeleton-text"
              style="--skeleton-width: 7.5rem; --skeleton-height: 1.45rem;"
            >
            </div>
          </div>
          <div
            class="flex w-full shrink-0 items-center justify-between gap-4 lg:ml-3 lg:mr-2 lg:w-auto lg:justify-start"
          >
            <div class="md3-skeleton-block h-6 w-8 rounded-lg"></div>
            <div class="md3-skeleton-block h-6 w-8 rounded-lg"></div>
            <div class="md3-skeleton-circle h-6 w-6"></div>
          </div>
        </div>
      </div>

      {
        hasCover ? (
          <div
            class:list={[
              "relative mx-4 mb-4 block h-44 rounded-xl overflow-hidden sm:mx-5 sm:mb-5 sm:h-48 md:h-52 lg:absolute lg:top-3 lg:right-3 lg:bottom-3 lg:mx-0 lg:mb-0 lg:h-auto",
              desktopEnterLinkClass,
            ]}
          >
            <div class="md3-skeleton-block h-full w-full rounded-xl" />
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="md3-skeleton-circle h-10 w-10" />
            </div>
          </div>
        ) : (
          <div
            class:list={[
              "hidden mx-5 mb-5 h-12 rounded-xl overflow-hidden lg:absolute lg:right-3 lg:top-3 lg:bottom-3 lg:mx-0 lg:mb-0 lg:flex lg:h-auto",
              desktopEnterLinkClass,
            ]}
          >
            <div class="md3-skeleton-block h-full w-full rounded-xl" />
          </div>
        )
      }
    </div>
  </div>
</div>
<div
  class="transition border-t border-dashed mx-6 border-black/10 dark:border-white/15 last:border-t-0 hidden"
>
</div>

<style define:vars={{ coverWidth }}></style>
<style>
  .post-card-menu summary::-webkit-details-marker {
    display: none;
  }
</style>
