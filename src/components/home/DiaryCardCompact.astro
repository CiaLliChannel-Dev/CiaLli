---
import type { AppDiary } from "@/types/app";
import { getResolvedSiteSettings } from "@/server/site-settings/service";
import {
  buildSiteDateFormatContext,
  formatSiteMonthDay,
} from "@/utils/date-utils";

interface Props {
  diary: AppDiary;
  username: string;
}

const { diary, username } = Astro.props;
const resolvedSiteSettings =
  Astro.locals.siteSettings ?? (await getResolvedSiteSettings());
const siteDateContext = buildSiteDateFormatContext(resolvedSiteSettings);

const href = `/${username}/diary/${diary.short_id || diary.id}`;

// 内容摘要
const excerpt = String(diary.content || "")
  .replace(/\s+/g, " ")
  .trim()
  .slice(0, 120);
const displayText =
  excerpt.length < (diary.content || "").replace(/\s+/g, " ").trim().length
    ? `${excerpt}...`
    : excerpt;

const dateStr = diary.date_created;
const formattedDate = dateStr
  ? formatSiteMonthDay(dateStr, siteDateContext)
  : "";
---

<a
  href={href}
  class="block shrink-0 w-[74vw] min-w-[17rem] max-w-[19rem] snap-start rounded-xl bg-black/5 p-3.5 transition-colors group min-h-[9.5rem] hover:bg-black/8 dark:bg-white/5 dark:hover:bg-white/8 sm:w-[280px] sm:min-w-0 sm:max-w-[280px] sm:min-h-[10rem] sm:p-4"
>
  <div>
    <!-- 内容摘要 -->
    <p
      class="text-sm text-75 line-clamp-3 leading-6 group-hover:text-(--primary) transition-colors"
    >
      {displayText}
    </p>
  </div>

  <!-- 底部日期 -->
  <div class="mt-3 pt-2 border-t border-black/5 dark:border-white/10">
    <span class="text-xs text-50">{formattedDate}</span>
  </div>
</a>
