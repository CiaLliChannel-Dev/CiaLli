---
import SideBarComponentList from "@components/widget/SideBarComponentList.astro";
import type { WidgetComponentConfig } from "@/types/config";
import { widgetManager } from "@utils/widget-manager";

function filterSupplementaryComponents(
  components: WidgetComponentConfig[],
): WidgetComponentConfig[] {
  return components.filter(
    (component) =>
      component.type !== "profile" && component.type !== "calendar",
  );
}

const topComponents = filterSupplementaryComponents(
  widgetManager.getComponentsByPosition("top", "left"),
);
const stickyComponents = filterSupplementaryComponents(
  widgetManager.getComponentsByPosition("sticky", "left"),
);
const hasSupplementaryComponents =
  topComponents.length > 0 || stickyComponents.length > 0;
---

{
  hasSupplementaryComponents && (
    <section class="mb-4 lg:hidden">
      <div class="flex flex-col gap-4">
        {/* 公开个人主页已在首屏展示资料卡，这里仅补充其余侧栏内容，避免手机端重复出现 Profile 卡。 */}
        {topComponents.length > 0 && (
          <SideBarComponentList components={topComponents} />
        )}
        {stickyComponents.length > 0 && (
          <SideBarComponentList components={stickyComponents} />
        )}
      </div>
    </section>
  )
}
