---
import { Icon } from "astro-icon/components";

interface Props {
  contentType: "article" | "diary";
  contentId: string;
  authorId: string;
  likeCount?: number;
  commentCount?: number;
  likedByViewer?: boolean;
  dockToBackTop?: boolean;
  editHref?: string;
  deleteEndpoint?: string;
  deleteConfirmMessage?: string;
  deleteSuccessHref?: string;
}

const {
  contentType,
  contentId,
  authorId,
  likeCount = 0,
  commentCount = 0,
  likedByViewer = false,
  dockToBackTop = false,
  editHref = "",
  deleteEndpoint = "",
  deleteConfirmMessage = "确认删除该内容？删除后不可恢复。",
  deleteSuccessHref = "/",
} = Astro.props;
---

<div
  class:list={["detail-action-float", dockToBackTop && "fixed-mode"]}
  data-content-type={contentType}
  data-content-id={contentId}
  data-author-id={authorId}
  data-like-count={String(likeCount)}
  data-comment-count={String(commentCount)}
  data-liked={likedByViewer ? "1" : "0"}
  data-dock-to-back-top={dockToBackTop ? "1" : "0"}
  data-edit-href={editHref}
  data-delete-endpoint={deleteEndpoint}
  data-delete-confirm-message={deleteConfirmMessage}
  data-delete-success-href={deleteSuccessHref}
>
  <div class="detail-action-bar card-base rounded-2xl">
    <button
      type="button"
      class="detail-action-btn detail-like-btn"
      aria-label="点赞"
    >
      <Icon name="material-symbols:thumb-up-rounded" class="detail-icon" />
      <span class="detail-action-count" data-like-count-text>{likeCount}</span>
    </button>
    <button
      type="button"
      class="detail-action-btn detail-comment-btn"
      aria-label="查看评论"
    >
      <Icon name="material-symbols:comment-rounded" class="detail-icon" />
      <span class="detail-action-count">{commentCount}</span>
    </button>
    <button
      type="button"
      class="detail-action-btn detail-manage-toggle hidden"
      aria-label="更多操作"
    >
      <Icon name="material-symbols:more-horiz" class="detail-icon" />
    </button>
  </div>

  <div class="detail-manage-panel">
    <button
      type="button"
      class="detail-manage-edit hidden w-full text-left px-3 py-2 rounded-lg text-sm text-90 hover:bg-black/5 dark:hover:bg-white/10"
    >
      编辑
    </button>
    <button
      type="button"
      class="detail-manage-delete hidden w-full text-left px-3 py-2 rounded-lg text-sm text-red-500 hover:bg-black/5 dark:hover:bg-white/10"
    >
      删除
    </button>
  </div>
</div>

<style lang="stylus">
  .detail-action-float
    position: relative
    width: var(--right-float-size, 3.75rem)
    margin-top: 9.5rem
    margin-left: 0
    margin-right: auto
    z-index: 30

    &.fixed-mode
      position: fixed
      right: var(--right-float-right, 6rem)
      bottom: calc(var(--back-to-top-bottom, 10rem) + var(--right-float-size, 3.75rem) + var(--right-float-gap, 0.75rem))
      top: auto
      margin: 0

    &[data-dock-to-back-top='1'].fixed-mode
      transform: translateX(var(--right-float-shift-x, 5rem))

    &.slot-mode
      margin-top: .5rem

  .detail-action-bar
    width: var(--right-float-size, 3.75rem)
    display: flex
    flex-direction: column
    align-items: center
    padding: .4rem
    gap: .15rem
    border: 1px solid var(--line-divider)

  .detail-action-btn
    width: 100%
    min-height: 3.35rem
    border: none
    background: transparent
    border-radius: .85rem
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    gap: .25rem
    color: var(--btn-content)
    transition: background-color .2s ease, color .2s ease

    &:hover
      background: var(--btn-card-bg-active)

    &.active
      color: var(--primary)

    &:disabled
      opacity: .65
      cursor: not-allowed

  .detail-icon
    font-size: 1.65rem

  .detail-action-count
    font-size: .95rem
    line-height: 1
    color: var(--text-60)

  .detail-manage-panel
    position: absolute
    bottom: 0
    left: calc(100% + .4rem)
    min-width: 8rem
    z-index: 60
    background: var(--card-bg)
    border: 1px solid var(--line-divider)
    border-radius: 1rem
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15)
    padding: 0.5rem
    opacity: 0
    visibility: hidden
    transform: translate(-6px, 6px) scale(0.95)
    transition: all 0.2s ease
    pointer-events: none

    &.show
      opacity: 1
      visibility: visible
      transform: translate(0, 0) scale(1)
      pointer-events: auto

  .detail-action-float.fixed-mode .detail-manage-panel
    left: auto
    right: calc(100% + .4rem)
    transform: translate(6px, 6px) scale(0.95)

  .detail-action-float.fixed-mode .detail-manage-panel.show
    transform: translate(0, 0) scale(1)

</style>

<script>
  import { getAuthState, subscribeAuthState } from "@/scripts/auth-state";
  import type { AuthState } from "@/scripts/auth-state";
  import { showAuthRequiredDialog } from "@/scripts/dialogs";
  import { navigateToPage } from "@/utils/navigation-utils";
  import {
    queryDetailElements,
    resolveAndMountElement,
    handleDeleteAction,
    handleLikeAction,
  } from "@/scripts/detail-action-float-helpers";
  import type { LikeActionState } from "@/scripts/detail-action-float-helpers";

  function bindDetailRoot(rootEl: HTMLElement): void {
    rootEl.dataset.bound = "1";
    const dockToBackTop = rootEl.dataset.dockToBackTop === "1";
    resolveAndMountElement({ rootEl, dockToBackTop });

    const contentType = String(rootEl.dataset.contentType || "");
    const contentId = String(rootEl.dataset.contentId || "");
    const authorId = String(rootEl.dataset.authorId || "");
    const editHref = String(rootEl.dataset.editHref || "");
    const deleteEndpoint = String(rootEl.dataset.deleteEndpoint || "");
    const deleteConfirmMessage = String(
      rootEl.dataset.deleteConfirmMessage || "确认删除该内容？删除后不可恢复。",
    );
    const deleteSuccessHref = String(rootEl.dataset.deleteSuccessHref || "/");

    const els = queryDetailElements(rootEl);
    const {
      likeBtn,
      commentBtn,
      manageBtn,
      panel,
      editBtn,
      deleteBtn,
      likeCountText,
    } = els;

    const likeState: LikeActionState = {
      liked: rootEl.dataset.liked === "1",
      likeCount: Number(rootEl.dataset.likeCount || "0") || 0,
      likePending: false,
    };
    let isOpen = false;

    function applyLikeUI(): void {
      const count = Math.max(0, likeState.likeCount);
      likeState.likeCount = count;
      rootEl.dataset.liked = likeState.liked ? "1" : "0";
      rootEl.dataset.likeCount = String(count);
      likeBtn?.classList.toggle("active", likeState.liked);
      likeBtn?.classList.toggle("is-pending", likeState.likePending);
      if (likeBtn) {
        likeBtn.disabled = likeState.likePending;
      }
      if (likeCountText) {
        likeCountText.textContent = String(count);
      }
    }

    function applyActionVisibility(state: AuthState): void {
      const canManage =
        state.isLoggedIn &&
        Boolean(state.userId) &&
        (state.isAdmin || state.userId === authorId);
      const canOpenPanel = canManage || state.isLoggedIn;

      manageBtn?.classList.toggle("hidden", !canOpenPanel);
      editBtn?.classList.toggle("hidden", !canManage);
      deleteBtn?.classList.toggle("hidden", !canManage);

      if (!canOpenPanel && isOpen) {
        panel?.classList.remove("show");
        isOpen = false;
      }
    }

    function openPanel(): void {
      isOpen = true;
      panel?.classList.add("show");
      manageBtn?.classList.add("active");
    }

    function closePanel(): void {
      isOpen = false;
      panel?.classList.remove("show");
      manageBtn?.classList.remove("active");
    }

    applyLikeUI();
    applyActionVisibility(getAuthState());
    subscribeAuthState((state) => applyActionVisibility(state));

    manageBtn?.addEventListener("click", (event) => {
      event.stopPropagation();
      if (isOpen) {
        closePanel();
      } else {
        openPanel();
      }
    });

    document.addEventListener("click", (event) => {
      if (!isOpen) return;
      if (!rootEl.contains(event.target as Node)) {
        closePanel();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && isOpen) {
        closePanel();
      }
    });

    editBtn?.addEventListener("click", () => {
      if (!editHref) return;
      closePanel();
      navigateToPage(editHref, { force: contentType === "diary" });
    });

    deleteBtn?.addEventListener("click", () => {
      if (!deleteBtn) return;
      void handleDeleteAction({
        deleteEndpoint,
        deleteConfirmMessage,
        deleteSuccessHref,
        contentType,
        deleteBtn,
        closePanel,
      });
    });

    likeBtn?.addEventListener("click", () => {
      if (likeState.likePending || !contentId) return;
      const auth = getAuthState();
      if (!auth.isLoggedIn) {
        showAuthRequiredDialog();
        return;
      }
      if (!likeBtn) return;
      void handleLikeAction({
        contentType,
        contentId,
        likeBtn,
        likeCountText,
        rootEl,
        state: likeState,
        applyLikeUI,
      });
    });

    commentBtn?.addEventListener("click", () => {
      const commentRoot = document.getElementById("comment-root");
      if (commentRoot) {
        commentRoot.scrollIntoView({ behavior: "smooth", block: "start" });
        return;
      }
      navigateToPage(`${window.location.pathname}#comment-root`);
    });
  }

  function initDetailActionFloat(): void {
    const roots = document.querySelectorAll<HTMLElement>(
      ".detail-action-float:not([data-bound='1'])",
    );
    roots.forEach((rootEl) => bindDetailRoot(rootEl));
  }

  type DetailActionRuntimeWindow = Window &
    typeof globalThis & {
      __detailActionSettledInitBound?: boolean;
    };

  const runtimeWindow = window as DetailActionRuntimeWindow;
  const NAVIGATION_SETTLED_EVENT = "cialli:navigation:settled";

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDetailActionFloat, {
      once: true,
    });
  } else {
    initDetailActionFloat();
  }

  if (!runtimeWindow.__detailActionSettledInitBound) {
    runtimeWindow.__detailActionSettledInitBound = true;
    // 统一在导航最终稳定后初始化，避免骨架阶段重复绑定引发二次动画体感
    document.addEventListener(NAVIGATION_SETTLED_EVENT, initDetailActionFloat);
  }
</script>
